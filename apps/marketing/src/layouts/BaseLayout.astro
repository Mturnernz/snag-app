---
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, ANALYTICS } from '../config';

interface Props {
  title: string;
  description?: string;
  /** Extra JSON-LD blocks beyond the default Organization */
  schema?: object[];
  /** 'snag' pages get the product header; 'docunation' the master brand */
  brand?: 'snag' | 'docunation';
}

const {
  title,
  description = SITE.description,
  schema = [],
  brand = 'snag',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.company,
  description: SITE.companyDescription,
  areaServed: SITE.regions,
  brand: { '@type': 'Brand', name: SITE.name },
};
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {schema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    {/* Analytics/pixels stay off until accounts exist — see src/config.ts */}
    {ANALYTICS.plausibleDomain && (
      <script defer data-domain={ANALYTICS.plausibleDomain} src="https://plausible.io/js/script.js" />
    )}
  </head>
  <body>
    <Header brand={brand} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
