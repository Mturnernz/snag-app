---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'center' | 'left';
  tone?: 'brand' | 'serious';
}
const { eyebrow, title, lead, align = 'center', tone = 'brand' } = Astro.props;
---

<div class:list={['max-w-2xl', align === 'center' ? 'mx-auto text-center' : '']}>
  {eyebrow && (
    <p class:list={[
      'text-xs font-bold tracking-widest uppercase',
      tone === 'serious' ? 'text-serious-600' : 'text-brand-600',
    ]}>{eyebrow}</p>
  )}
  <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">{title}</h2>
  {lead && <p class="mt-4 text-lg leading-relaxed text-ink-2">{lead}</p>}
</div>
