{
  "expo": {
    "name": "Snag",
    "slug": "snag",
    "owner": "mturnernz1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snag.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.snag.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Snag needs access to your photos to attach images to issue reports.",
          "cameraPermission": "Snag needs access to your camera to take photos of issues."
        }
      ],
      "expo-asset",
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "Snag",
      "shortName": "Snag",
      "description": "Workplace issue reporting",
      "themeColor": "#2563EB",
      "backgroundColor": "#F9FAFB",
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "eas": {
        "projectId": "fc3e5412-bd53-459a-b572-d7d85283377b"
      }
    }
  }
}
