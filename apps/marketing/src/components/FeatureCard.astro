---
interface Props {
  title: string;
  body: string;
  icon: 'camera' | 'route' | 'shield' | 'people' | 'sites' | 'chart' | 'merge' | 'globe' | 'doc';
  tone?: 'brand' | 'serious';
}
const { title, body, icon, tone = 'brand' } = Astro.props;

const paths: Record<Props['icon'], string> = {
  camera: 'M3 8a2 2 0 012-2h1.2l1-2h9.6l1 2H19a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm9 9a4 4 0 100-8 4 4 0 000 8z',
  route: 'M6 3a3 3 0 100 6c4 0 8 1 8 5a3 3 0 11-3 3M6 6h.01M18 17h.01',
  shield: 'M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3zm-2 9l2 2 3.5-4',
  people: 'M8 11a3 3 0 100-6 3 3 0 000 6zm8 0a3 3 0 100-6 3 3 0 000 6zM2 20c0-3 3-5 6-5s6 2 6 5m2-5c2.5.3 6 1.8 6 5',
  sites: 'M3 21V8l6-4 6 4v13M9 21v-6h6v6M15 12h6v9M3 21h18',
  chart: 'M4 20V10m6 10V4m6 16v-7m4 7H2',
  merge: 'M7 4v6c0 3 2 5 5 5h5m0 0l-3-3m3 3l-3 3M7 20v-4',
  globe: 'M12 21a9 9 0 100-18 9 9 0 000 18zm-9-9h18M12 3c2.5 2.4 4 5.6 4 9s-1.5 6.6-4 9c-2.5-2.4-4-5.6-4-9s1.5-6.6 4-9z',
  doc: 'M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1zm7 0v5h5M9 13h6M9 17h6',
};
---

<article class="rounded-(--radius-card) border border-line bg-white p-6 shadow-sm">
  <div class:list={[
    'flex h-11 w-11 items-center justify-center rounded-(--radius-btn)',
    tone === 'serious' ? 'bg-serious-bg text-serious-600' : 'bg-brand-100 text-brand-600',
  ]}>
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d={paths[icon]} />
    </svg>
  </div>
  <h3 class="mt-4 text-base font-bold text-ink">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-ink-2">{body}</p>
</article>
