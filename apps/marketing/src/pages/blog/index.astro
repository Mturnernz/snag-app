---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = new Intl.DateTimeFormat('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Resources — SNAG"
  description="Plain-English guides to health & safety reporting, HSWA 2015 and WHS Act obligations, and building a reporting culture in NZ and AU workplaces."
>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-5 py-16 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">Resources</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ink-2">
        Plain-English guides to H&amp;S reporting and compliance for NZ and AU
        businesses. No jargon, no scaremongering.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-24">
    <ul class="space-y-6">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`} class="block rounded-(--radius-card) border border-line bg-white p-7 shadow-sm transition-shadow hover:shadow-md">
            <p class="text-xs font-semibold text-ink-3">{fmt.format(post.data.pubDate)}</p>
            <h2 class="mt-2 text-xl font-bold text-ink">{post.data.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-2">{post.data.description}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600">Read article →</span>
          </a>
        </li>
      ))}
    </ul>
    {posts.length === 0 && <p class="text-center text-ink-3">Articles coming soon.</p>}
  </section>
</BaseLayout>
