---
interface Props {
  title?: string;
  body?: string;
}
const {
  title = 'Ready to sort the snags?',
  body = 'Get early access for your team, or talk to us about rolling SNAG out across your sites.',
} = Astro.props;
---

<section class="bg-navy-900">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-5 py-16 text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{title}</h2>
    <p class="max-w-xl text-white/70">{body}</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact" class="rounded-(--radius-btn) bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-500">Get early access</a>
      <a href="/features" class="rounded-(--radius-btn) border border-white/25 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10">See the features</a>
    </div>
  </div>
</section>
