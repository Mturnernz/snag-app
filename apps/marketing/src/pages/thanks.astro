---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thanks — SNAG" description="We've got your request and will be in touch shortly.">
  <section class="mx-auto flex max-w-xl flex-col items-center px-5 py-32 text-center">
    <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-100">
      <svg class="h-8 w-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </span>
    <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-ink">Snagged it.</h1>
    <p class="mt-3 text-ink-2">
      Thanks — we've got your request and we'll be in touch, usually within a day.
    </p>
    <a href="/" class="mt-8 rounded-(--radius-btn) border border-line px-6 py-3 text-sm font-semibold text-ink hover:border-brand-600 hover:text-brand-600">Back to the site</a>
  </section>
</BaseLayout>
